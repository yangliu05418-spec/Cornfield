      "$type": "color",
      "$value": "#1c1e20",
      "$description": "Card and panel surfaces, nav bar background"
    },
    "Surface Secondary": {
      "$type": "color",
      "$value": "#23262a",
      "$description": "Secondary panels, download panel, glass overlays"
