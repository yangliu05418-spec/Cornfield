    },
    "Dark Ink": {
      "$type": "color",
      "$value": "#131517",
      "$description": "Button text on lime CTA, icon fills on inverted surfaces"
    },
    "Page Background Light": {
      "$type": "color",
      "$value": "#f7f7f8",
      "$description": "Light mode page canvas (same token, inverted role)"
