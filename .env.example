APP_ENV=production
APP_PUBLIC_URL=https://studio.internal.example
DATA_ROOT=/srv/internal-image-studio/data
# Host-only deployment checks; match the enabled site path and nginx.conf user.
NGINX_SITE_CONFIG=/etc/nginx/sites-enabled/internal-image-studio.conf
NGINX_WORKER_USER=www-data
SESSION_COOKIE_SECURE=true
SESSION_TTL=12h
SESSION_IDLE_TTL=2h
PROVIDER_MODE=live
LOG_LEVEL=info
POSTGRES_BOOTSTRAP_PASSWORD_SECRET_SOURCE=./secrets/postgres_bootstrap_password
POSTGRES_OWNER_PASSWORD_SECRET_SOURCE=./secrets/postgres_owner_password
POSTGRES_API_PASSWORD_SECRET_SOURCE=./secrets/postgres_api_password
POSTGRES_WORKER_PASSWORD_SECRET_SOURCE=./secrets/postgres_worker_password
LEGNEXT_API_KEY_SECRET_SOURCE=./secrets/legnext_api_key
OPENROUTER_API_KEY_SECRET_SOURCE=./secrets/openrouter_api_key
PROVIDER_CALLBACK_SECRET_SOURCE=./secrets/provider_callback_secret
PROVIDER_URL_SIGNING_SECRET_SOURCE=./secrets/provider_url_signing_secret
GRAFANA_ADMIN_PASSWORD_SECRET_SOURCE=./secrets/grafana_admin_password
# Optional after an HTTPS receiver has been configured and tested:
# COMPOSE_PROFILES=observability,alerting
# ALERTMANAGER_WEBHOOK_URL_SECRET_SOURCE=./secrets/alertmanager_webhook_url
RELEASE_REQUIRE_DIGESTS=true
# Replace all four values with the exact references from the release workflow's
# verified digests.env artifact. Preflight intentionally rejects these placeholders.
API_IMAGE=ghcr.io/replace-owner/cornfield-api@sha256:<from-release-artifact>
WORKER_IMAGE=ghcr.io/replace-owner/cornfield-worker@sha256:<from-release-artifact>
TOOLS_IMAGE=ghcr.io/replace-owner/cornfield-tools@sha256:<from-release-artifact>
WEB_IMAGE=ghcr.io/replace-owner/cornfield-web@sha256:<from-release-artifact>
STUDIO_ROOT=/opt/internal-image-studio
BACKUP_STAGE=/var/backups/internal-image-studio
RESTORE_CHECK_SAMPLE_SIZE=20
